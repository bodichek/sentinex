# Sentinex — Environment Variables Template
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# ------------------------------------------------------------
# Django Core
# ------------------------------------------------------------

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Environment: development, staging, production
DJANGO_ENV=development

# Debug mode (must be False in production)
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.sentinex.local

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# Full connection string
DATABASE_URL=postgres://sentinex:sentinex@localhost:5432/sentinex

# Or individual components (used as fallback if DATABASE_URL unset)
POSTGRES_DB=sentinex
POSTGRES_USER=sentinex
POSTGRES_PASSWORD=sentinex
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# Celery uses same Redis by default
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI API key — used only for embeddings
OPENAI_API_KEY=

# Default LLM model selection
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_MODEL=claude-haiku-4-5-20251001

# LLM cache config
LLM_CACHE_ENABLED=True
LLM_CACHE_DEFAULT_TTL=3600

# ------------------------------------------------------------
# OAuth — Google Workspace
# ------------------------------------------------------------

# From Google Cloud Console (OAuth 2.0 Client IDs)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Authorized redirect URIs (configured in Google Cloud Console):
# Dev: http://{tenant}.sentinex.local:8000/integrations/google_workspace/callback/
# Prod: https://{tenant}.sentinex.<tld>/integrations/google_workspace/callback/

# ------------------------------------------------------------
# Encryption (django-cryptography)
# ------------------------------------------------------------

# 32+ character key for field-level encryption
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRYPTOGRAPHY_KEY=

# ------------------------------------------------------------
# Email
# ------------------------------------------------------------

# Dev: console backend (prints emails to stdout)
# Prod: smtp backend with real SMTP settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@sentinex.local

# SMTP settings (production)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.provider.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------

# Sentry DSN — get from sentry.io
SENTRY_DSN=

# Sentry environment tag
SENTRY_ENVIRONMENT=development

# ------------------------------------------------------------
# Tenancy
# ------------------------------------------------------------

# Base domain for tenants (used in subdomain routing)
TENANT_HOST=sentinex.local

# ------------------------------------------------------------
# Pricing
# ------------------------------------------------------------

# USD to CZK exchange rate (for cost calculation)
USD_TO_CZK=24.0

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------

# Session cookie age in seconds (default: 24 hours)
SESSION_COOKIE_AGE=86400

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.sentinex.local
